<!-- Call-to-Action Section -->
<section style="padding: 4rem 0; text-align: center;">
    <div class="container-sm">
        <h2 style="margin-bottom: 1rem;">Ready to Master English?</h2>
        <p style="font-size: 1.125rem; color: #6C757D; margin-bottom: 2rem;">Join thousands of learners improving their English skills with AI-powered personalized learning.</p>

        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/register" Size="Size.Large" Style="font-weight: 600;">
                Create Free Account
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/login" Size="Size.Large" Style="font-weight: 600;">
                Already Have an Account?
            </MudButton>
        </div>
    </div>
