@page "/"
@attribute [AllowAnonymous]

<PageTitle>English Architect AI - Master English from A1 to C2</PageTitle>

<!-- Hero Section -->
<section class="hero">
    <div class="container">
        <h1 class="hero-title animate-fade-in">Master English with AI-Powered Learning</h1>
        <p class="hero-subtitle animate-fade-in">From beginner (A1) to mastery (C2), personalized lessons, smart practice, and daily content refreshes.</p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-top: 2rem;">
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" Href="/register" Size="Size.Large" Style="background-color: #F5B041; color: white; font-weight: 600;">
                Start Your Journey
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/login" Size="Size.Large" Style="border-color: white; color: white; font-weight: 600;">
                Sign In
            </MudButton>
        </div>
    </div>
</section>

<!-- Features Section -->
<section style="padding: 3rem 0;">
    <div class="container">
        <h2 style="text-align: center; margin-bottom: 3rem;">Why Choose English Architect AI?</h2>

        <div class="feature-grid">
            <!-- Feature 1 -->
            <div class="feature-card animate-fade-in">
                <div class="feature-icon">🎓</div>
                <h3>Comprehensive Learning Path</h3>
                <p>Follow the CEFR framework from A1 (beginner) through C2 (mastery). Each level builds on the previous with structured modules and lessons.</p>
            </div>

            <!-- Feature 2 -->
            <div class="feature-card animate-fade-in">
                <div class="feature-icon">🤖</div>
                <h3>AI-Powered Content</h3>
                <p>Get daily exercise variations and content refreshes. Our AI generates contextual examples and new learning materials automatically.</p>
            </div>

            <!-- Feature 3 -->
            <div class="feature-card animate-fade-in">
                <div class="feature-icon">📊</div>
                <h3>Smart Progress Tracking</h3>
                <p>Monitor your learning with detailed progress reports. Identify weaknesses and focus on areas that need improvement.</p>
            </div>

            <!-- Feature 4 -->
            <div class="feature-card animate-fade-in">
                <div class="feature-icon">🔄</div>
                <h3>Spaced Repetition</h3>
                <p>Use the power of spaced repetition to retain what you learn. Our system schedules reviews at optimal intervals for long-term memory.</p>
            </div>

            <!-- Feature 5 -->
            <div class="feature-card animate-fade-in">
                <div class="feature-icon">🎯</div>
                <h3>Placement Testing</h3>
                <p>Take our smart placement test to find your starting level. Get accurate assessment based on CEFR standards.</p>
            </div>

            <!-- Feature 6 -->
            <div class="feature-card animate-fade-in">
                <div class="feature-icon">🏆</div>
                <h3>Earn Certificates</h3>
                <p>Complete levels and earn official certificates. Verify your English proficiency with verifiable credentials.</p>
            </div>
        </div>
    </div>
</section>

<!-- CEFR Levels Section -->
<section style="background-color: #F8F9FA; padding: 3rem 0;">
    <div class="container">
        <h2 style="text-align: center; margin-bottom: 3rem;">CEFR Learning Levels</h2>

        <div class="row-2">
            <!-- A1-A2 -->
            <div class="card">
                <div class="card-header">
                    <h3 style="margin: 0; color: white; font-size: 1.5rem;">Elementary</h3>
                </div>
                <div class="card-body">
                    <p><strong class="level-badge level-a1">A1 Beginner</strong></p>
                    <p>Start from scratch. Learn basic greetings, simple sentences, and essential vocabulary for everyday situations.</p>
                    <hr style="border: none; border-top: 1px solid #DEE2E6; margin: 1rem 0;">
                    <p><strong class="level-badge level-a2">A2 Elementary</strong></p>
                    <p>Build confidence with past tense, simple conversations, and practical communication skills.</p>
                </div>
            </div>

            <!-- B1-B2 -->
            <div class="card">
                <div class="card-header">
                    <h3 style="margin: 0; color: white; font-size: 1.5rem;">Intermediate</h3>
                </div>
                <div class="card-body">
                    <p><strong class="level-badge level-b1">B1 Intermediate</strong></p>
                    <p>Express opinions, discuss complex topics, and understand main points of conversations.</p>
                    <hr style="border: none; border-top: 1px solid #DEE2E6; margin: 1rem 0;">
                    <p><strong class="level-badge level-b2">B2 Upper-Intermediate</strong></p>
                    <p>Master advanced grammar, write fluently, and understand detailed arguments.</p>
                </div>
            </div>

            <!-- C1-C2 -->
            <div class="card">
                <div class="card-header">
                    <h3 style="margin: 0; color: white; font-size: 1.5rem;">Advanced</h3>
                </div>
                <div class="card-body">
                    <p><strong class="level-badge level-c1">C1 Advanced</strong></p>
                    <p>Handle complex and demanding situations. Understand nuanced meanings and express yourself spontaneously.</p>
                    <hr style="border: none; border-top: 1px solid #DEE2E6; margin: 1rem 0;">
                    <p><strong class="level-badge level-c2">C2 Mastery</strong></p>
                    <p>Near-native proficiency. Master sophisticated language and master all nuances of English.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How It Works Section -->
<section style="padding: 3rem 0;">
    <div class="container-sm">
        <h2 style="text-align: center; margin-bottom: 3rem;">How It Works</h2>

        <div style="display: grid; gap: 2rem;">
            <!-- Step 1 -->
            <div style="display: grid; grid-template-columns: 100px 1fr; gap: 2rem; align-items: start;">
                <div style="background: linear-gradient(135deg, #003D7A 0%, #0052A3 100%); color: white; padding: 1.5rem; border-radius: 50%; text-align: center; font-size: 2rem; font-weight: 700; display: flex; align-items: center; justify-content: center;">1</div>
                <div>
                    <h3 style="color: #003D7A;">Take a Placement Test</h3>
                    <p style="color: #6C757D;">Start by taking our smart placement test. It will assess your current English level and recommend the perfect starting point.</p>
                </div>
            </div>

            <!-- Step 2 -->
            <div style="display: grid; grid-template-columns: 100px 1fr; gap: 2rem; align-items: start;">
                <div style="background: linear-gradient(135deg, #003D7A 0%, #0052A3 100%); color: white; padding: 1.5rem; border-radius: 50%; text-align: center; font-size: 2rem; font-weight: 700; display: flex; align-items: center; justify-content: center;">2</div>
                <div>
                    <h3 style="color: #003D7A;">Learn & Practice</h3>
                    <p style="color: #6C757D;">Complete structured lessons with grammar explanations, vocabulary, and interactive exercises. Get instant feedback on your answers.</p>
                </div>
            </div>

            <!-- Step 3 -->
            <div style="display: grid; grid-template-columns: 100px 1fr; gap: 2rem; align-items: start;">
                <div style="background: linear-gradient(135deg, #003D7A 0%, #0052A3 100%); color: white; padding: 1.5rem; border-radius: 50%; text-align: center; font-size: 2rem; font-weight: 700; display: flex; align-items: center; justify-content: center;">3</div>
                <div>
                    <h3 style="color: #003D7A;">Review with Spaced Repetition</h3>
                    <p style="color: #6C757D;">Strengthen your knowledge using scientifically-proven spaced repetition. Review cards are scheduled at the optimal time for your memory.</p>
                </div>
            </div>

            <!-- Step 4 -->
            <div style="display: grid; grid-template-columns: 100px 1fr; gap: 2rem; align-items: start;">
                <div style="background: linear-gradient(135deg, #003D7A 0%, #0052A3 100%); color: white; padding: 1.5rem; border-radius: 50%; text-align: center; font-size: 2rem; font-weight: 700; display: flex; align-items: center; justify-content: center;">4</div>
                <div>
                    <h3 style="color: #003D7A;">Track Progress & Advance</h3>
                    <p style="color: #6C757D;">Monitor your growth with detailed analytics. Complete lessons, unlock achievements, and progress toward your next level.</p>
                </div>
            </div>

            <!-- Step 5 -->
            <div style="display: grid; grid-template-columns: 100px 1fr; gap: 2rem; align-items: start;">
                <div style="background: linear-gradient(135deg, #003D7A 0%, #0052A3 100%); color: white; padding: 1.5rem; border-radius: 50%; text-align: center; font-size: 2rem; font-weight: 700; display: flex; align-items: center; justify-content: center;">5</div>
                <div>
                    <h3 style="color: #003D7A;">Earn Certificates</h3>
                    <p style="color: #6C757D;">Upon completing each level, earn an official certificate. Share your achievement and verify your English proficiency.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Highlight Section -->
