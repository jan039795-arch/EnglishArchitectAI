@page "/levels/{LevelId:guid}"
@attribute [Authorize]
@inject EA.Client.Services.ApiService Api
@inject NavigationManager Nav

<PageTitle>Modules — English Architect AI</PageTitle>

@if (_loading)
{
    <div style="display: flex; justify-content: center; padding: 3rem;">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
    </div>
}
else if (_level is null)
{
    <MudAlert Severity="Severity.Error" Style="margin-bottom: 2rem;">
        ❌ Level not found
    </MudAlert>
}
else
{
    <!-- Page Header -->
    <div style="margin-bottom: 2rem;">
        <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4 pa-0" />
        <h1 style="color: #003D7A; margin: 0 0 0.5rem 0;">📚 @_level.Code — @_level.Name</h1>
        <p style="color: #6C757D; font-size: 1.1rem; margin: 0;">Complete each module to progress through the level and deepen your understanding.</p>
    </div>

    @if (_modules.Count == 0)
    {
        <div class="alert alert-info">
            <span>ℹ️ No modules available yet for this level. Check back soon!</span>
        </div>
    }
    else
    {
        <div style="max-width: 900px;">
            @foreach (var (mod, idx) in _modules.Select((m, i) => (m, i)))
            {
                var stepNumber = idx + 1;
                var isOdd = idx % 2 == 0;

                <div style="display: grid; grid-template-columns: 80px 1fr; gap: 2rem; margin-bottom: 3rem; align-items: stretch;">
                    <!-- Timeline number -->
                    <div style="display: flex; flex-direction: column; align-items: center;">
                        <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #003D7A 0%, #0052A3 100%); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">
                            @stepNumber
                        </div>
                        @if (stepNumber < _modules.Count)
                        {
                            <div style="width: 2px; height: 120px; background: linear-gradient(180deg, #003D7A 0%, transparent 100%);"></div>
                        }
                    </div>

                    <!-- Module Card -->
                    <div class="card" style="cursor: pointer; transition: all 300ms ease-in-out;"
                         @onclick="@(() => Nav.NavigateTo($"/modules/{mod.Id}"))">
                        <div style="display: flex; gap: 1.5rem;">
                            <div style="flex: 1;">
                                <div style="color: #003D7A; font-size: 0.875rem; font-weight: 700; text-transform: uppercase; margin-bottom: 0.5rem;">
                                    📖 Module @stepNumber
                                </div>
                                <h3 style="color: #003D7A; margin: 0 0 0.5rem 0; font-size: 1.25rem;">@mod.Title</h3>
                                <p style="color: #6C757D; margin: 0 0 1rem 0; line-height: 1.5;">@mod.Description</p>

                                <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
                                    <div style="display: flex; align-items: center; gap: 0.5rem; color: #6C757D; font-size: 0.9rem;">
                                        <span>⏱️</span> <span>~@mod.EstimatedHours hours</span>
                                    </div>
                                </div>
                            </div>

                            <div style="display: flex; align-items: center; justify-content: center; width: 50px; height: 50px; background-color: #F8F9FA; border-radius: 0.5rem; flex-shrink: 0;">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Medium" Color="Color.Primary" />
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    [Parameter] public Guid LevelId { get; set; }

    private bool _loading = true;
    private EA.Client.Services.LevelDto? _level;
    private List<EA.Client.Services.ModuleDto> _modules = [];
    private List<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnInitializedAsync()
    {
        _level = await Api.GetLevelByIdAsync(LevelId);
        if (_level is not null)
            _modules = await Api.GetModulesByLevelAsync(LevelId) ?? [];

        _breadcrumbs =
        [
            new("My Path", "/levels"),
            new(_level?.Code ?? "Level", null, disabled: true),
        ];
        _loading = false;
    }
}
