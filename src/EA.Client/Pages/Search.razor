@page "/search"
@attribute [Authorize]
@inject EA.Client.Services.ApiService Api
@inject NavigationManager Nav

<PageTitle>Search Lessons — English Architect AI</PageTitle>

<!-- Page Header -->
<div style="margin-bottom: 2rem;">
    <h1 style="color: #003D7A; margin: 0 0 0.5rem 0;">🔍 Search Lessons</h1>
    <p style="color: #6C757D; font-size: 1.1rem; margin: 0;">Find lessons across all levels and modules. Search by title or keyword.</p>
</div>

<!-- Search Box -->
<div style="background: white; border-radius: 0.75rem; padding: 2rem; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06); margin-bottom: 2rem;">
    <div style="display: flex; gap: 1rem;">
        <MudTextField @bind-Value="_searchTerm"
                      Placeholder="Enter lesson title or keyword..."
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      Margin="Margin.Dense" />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="PerformSearch"
                   Disabled="_searching"
                   Size="Size.Medium"
                   Style="font-weight: 600;">
            @if (_searching)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                <span>Searching...</span>
            }
            else
            {
                <span>Search</span>
            }
        </MudButton>
    </div>
</div>

<!-- Results -->
@if (_results.Count == 0 && !_searching && _searched)
{
    <div class="alert alert-info">
        <span>ℹ️ No lessons found matching "<strong>@_searchTerm</strong>". Try a different search term.</span>
    </div>
}
else if (_results.Count > 0)
{
    <div style="margin-bottom: 1.5rem;">
        <p style="color: #6C757D;"><strong>@_results.Count</strong> result(s) found</p>
    </div>

    <div style="display: grid; gap: 1.5rem;">
        @foreach (var result in _results)
        {
            <div class="card" style="cursor: pointer;"
                 @onclick="@(() => OpenLesson(result))">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
                    <div style="flex: 1;">
                        <h3 style="color: #003D7A; margin: 0 0 0.5rem 0;">@result.LessonTitle</h3>
                        <p style="color: #6C757D; margin: 0 0 1rem 0; font-size: 0.95rem;">
                            <strong>Module:</strong> @result.ModuleTitle
                        </p>
                        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                            <span class="level-badge @("level-" + result.LevelCode.ToLowerInvariant())">
                                @result.LevelCode
                            </span>
                        </div>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Color="Color.Primary" Size="Size.Medium" />
                </div>
            </div>
        }
    </div>
}

@code {
    private string _searchTerm = string.Empty;
    private List<EA.Client.Services.SearchLessonDto> _results = [];
    private bool _searching = false;
    private bool _searched = false;

    private async Task PerformSearch()
    {
        if (string.IsNullOrWhiteSpace(_searchTerm) || _searchTerm.Length < 2)
        {
            return;
        }

        _searching = true;
        _searched = true;
        _results = await Api.SearchLessonsAsync(_searchTerm) ?? [];
        _searching = false;
    }

    private void OpenLesson(EA.Client.Services.SearchLessonDto result)
    {
        Nav.NavigateTo($"/lessons/{result.LessonId}");
    }
}
