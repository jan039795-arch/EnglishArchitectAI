@page "/certificates"
@attribute [Authorize]
@inject EA.Client.Services.ApiService Api
@inject NavigationManager Nav

<PageTitle>Certificates — English Architect AI</PageTitle>

<!-- Page Header -->
<div style="margin-bottom: 2rem;">
    <h1 style="color: #003D7A; margin: 0 0 0.5rem 0;">🏆 My Certificates</h1>
    <p style="color: #6C757D; font-size: 1.1rem; margin: 0;">Earn certificates by completing all lessons in a level. Showcase your achievements and verify your English proficiency.</p>
</div>

@if (_loading)
{
    <div style="display: flex; justify-content: center; padding: 3rem;">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
    </div>
}
else
{
    <MudTabs Elevation="0" PanelClass="mud-height-full">
        <MudTabPanel Text="📜 Earned Certificates">
            @if (_certificates.Count == 0)
            {
                <div class="alert alert-info" style="margin-top: 2rem;">
                    <span>ℹ️ You haven't earned any certificates yet. Complete all lessons in a level to earn one!</span>
                </div>
            }
            else
            {
                <div style="display: grid; gap: 2rem; margin-top: 2rem;">
                    @foreach (var cert in _certificates)
                    {
                        <div class="card">
                            <div style="display: flex; gap: 2rem; align-items: flex-start;">
                                <div style="font-size: 3rem; display: flex; align-items: center;">🏆</div>
                                <div style="flex: 1;">
                                    <h3 style="color: #003D7A; margin: 0 0 0.5rem 0; font-size: 1.25rem;">
                                        English Architect AI — @cert.LevelCode Certificate
                                    </h3>
                                    <p style="color: #6C757D; margin: 0 0 1rem 0;">
                                        <strong>Issued:</strong> @cert.IssuedAt.ToString("MMMM d, yyyy")
                                    </p>
                                    <p style="color: #6C757D; font-size: 0.875rem; margin: 0;">
                                        <strong>Verification Code:</strong> <code>@cert.VerificationCode</code>
                                    </p>
                                </div>
                                <div style="display: flex; gap: 0.5rem; flex-direction: column; flex-shrink: 0;">
                                    @if (!string.IsNullOrEmpty(cert.PDFBlobUrl))
                                    {
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Href="@cert.PDFBlobUrl"
                                                   Target="_blank"
                                                   Style="font-weight: 600;">
                                            📥 Download PDF
                                        </MudButton>
                                    }
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               Href="@($"/certificates/verify/{cert.VerificationCode}")"
                                               Target="_blank"
                                               Style="font-weight: 600;">
                                        ✓ Verify
                                    </MudButton>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </MudTabPanel>

        <MudTabPanel Text="🎯 Request Certificate">
            @if (_levels.Count == 0)
            {
                <div class="alert alert-info" style="margin-top: 2rem;">
                    <span>ℹ️ No levels available.</span>
                </div>
            }
            else
            {
                <div style="display: grid; gap: 1.5rem; margin-top: 2rem;">
                    @foreach (var level in _levels)
                    {
                        var hasCert = _certificates.Any(c => c.LevelCode == level.Code);
                        <div class="card" style="@(hasCert ? "opacity: 0.7;" : "")">
                            <div style="display: flex; justify-content: space-between; align-items: center; gap: 2rem;">
                                <div>
                                    <h3 style="color: #003D7A; margin: 0 0 0.5rem 0;">@level.Name <span class="level-badge @("level-" + level.Code.ToLowerInvariant())">@level.Code</span></h3>
                                    <p style="color: #6C757D; margin: 0;">
                                        @if (hasCert)
                                        {
                                            <span>✓ <strong>Certificate earned</strong></span>
                                        }
                                        else
                                        {
                                            <span>Complete all lessons to unlock certificate</span>
                                        }
                                    </p>
                                </div>
                                @if (!hasCert)
                                {
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               OnClick="@(() => RequestCertificate(level.Code))"
                                               Disabled="@_issuing"
                                               Style="font-weight: 600; flex-shrink: 0;">
                                        @if (_issuingLevel == level.Code && _issuing)
                                        {
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                                            <span>Requesting...</span>
                                        }
                                        else
                                        {
                                            <span>Request Certificate</span>
                                        }
                                    </MudButton>
                                }
                                else
                                {
                                    <span style="font-weight: 600; color: #27AE60;">✓ Completed</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </MudTabPanel>
    </MudTabs>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mt-4">@_errorMessage</MudAlert>
    }
    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <MudAlert Severity="Severity.Success" Class="mt-4">@_successMessage</MudAlert>
    }
}

@code {
    private bool _loading = true;
    private List<EA.Client.Services.CertificateDto> _certificates = [];
    private List<EA.Client.Services.LevelDto> _levels = [];
    private bool _issuing = false;
    private string _issuingLevel = string.Empty;
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var certsTask = Api.GetCertificatesAsync();
        var levelsTask = Api.GetLevelsAsync();

        await Task.WhenAll(certsTask, levelsTask);

        _certificates = await certsTask ?? [];
        _levels = await levelsTask ?? [];
        _loading = false;
    }

    private async Task RequestCertificate(string levelCode)
    {
        _issuing = true;
        _issuingLevel = levelCode;
        _errorMessage = string.Empty;
        _successMessage = string.Empty;

        var result = await Api.IssueCertificateAsync(levelCode);
        if (result is not null)
        {
            _certificates.Add(result);
            _successMessage = $"Certificate for {levelCode} issued successfully!";
        }
        else
        {
            _errorMessage = "Failed to issue certificate. Please ensure you have completed all lessons for this level.";
        }

        _issuing = false;
        _issuingLevel = string.Empty;
    }
}
