@inherits LayoutComponentBase
@inject NavigationManager Nav

<div style="min-height: 100vh; background-color: #FFFFFF;">
    <nav style="background: linear-gradient(135deg, #003D7A 0%, #0052A3 100%); padding: 20px 40px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
        <div style="display: flex; justify-content: space-between; align-items: center; color: white;">
            <h2 style="margin: 0; font-weight: 700; font-size: 20px;">📚 English Architect AI</h2>
            <div style="display: flex; gap: 15px;">
                <a href="/login" style="color: white; text-decoration: none; padding: 8px 16px; border-radius: 4px; font-weight: 600; font-size: 14px; background: transparent; border: 2px solid white; transition: all 0.3s;">Sign In</a>
                <a href="/register" style="color: white; text-decoration: none; padding: 8px 16px; border-radius: 4px; font-weight: 600; font-size: 14px; background: #E84C3D; border: 2px solid #E84C3D; transition: all 0.3s;">Register</a>
            </div>
        </div>
    </nav>

    <main style="padding: 40px 20px; max-width: 1200px; margin: 0 auto;">
        @Body
    </main>

    <footer style="background-color: #F8F9FA; padding: 40px 20px; text-align: center; color: #6C757D; margin-top: 60px; border-top: 1px solid #E9ECEF;">
        <p style="margin: 0;">&copy; 2026 English Architect AI. All rights reserved.</p>
    </footer>
</div>
