{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=EnglishArchitectAI;Trusted_Connection=True;MultipleActiveResultSets=true",
    "Redis": "localhost:6379"
  },
  "JwtSettings": {
    "Secret": "CHANGE_ME_TO_A_SECURE_RANDOM_KEY_AT_LEAST_32_CHARS",
    "Issuer": "EnglishArchitectAI",
    "Audience": "EnglishArchitectAI.Client",
    "ExpiresInMinutes": 60
  },
  "AzureOpenAI": {
    "Endpoint": "https://YOUR_RESOURCE.openai.azure.com/",
    "ApiKey": "YOUR_AZURE_OPENAI_KEY",
    "DeploymentName": "gpt-4o"
  },
  "AzureSpeech": {
    "SubscriptionKey": "YOUR_AZURE_SPEECH_KEY",
    "Region": "eastus"
  },
  "MercadoPago": {
    "AccessToken": "YOUR_MERCADOPAGO_ACCESS_TOKEN"
  },
  "ClientUrl": "http://localhost:5160",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
